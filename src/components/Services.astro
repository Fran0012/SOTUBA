---
const services = [
  {
    icon: 'code',
    title: 'Consultoría en Desarrollo de Software',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.',
  },
  {
    icon: 'shield',
    title: 'Auditoría de Sistemas',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent commodo cursus magna, vel scelerisque nisl consectetur et.',
  },
  {
    icon: 'rocket',
    title: 'Transformación Digital',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam quis risus eget urna mollis ornare vel eu leo.',
  },
  {
    icon: 'book',
    title: 'Capacitación IT',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras mattis consectetur purus sit amet fermentum.',
  },
];

const icons: Record<string, string> = {
  code: '<path d="M16 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" stroke="currentColor" stroke-width="2" fill="none"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" stroke="currentColor" stroke-width="2" fill="none"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" stroke="currentColor" stroke-width="2" fill="none"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" stroke="currentColor" stroke-width="2" fill="none"/>',
  book: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" stroke="currentColor" stroke-width="2" fill="none"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" stroke="currentColor" stroke-width="2" fill="none"/>',
};
---

<section class="services section section--alt" id="servicios">
  <div class="container">
    <div class="services__header animate-on-scroll">
      <span class="section-label">Servicios</span>
      <h2 class="section-title">
        Soluciones <span class="text-gradient">a medida</span> para cada desafío
      </h2>
      <p class="section-subtitle">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ofrecemos un
        abanico de servicios diseñados para potenciar la tecnología en tu organización.
      </p>
    </div>

    <div class="services__grid stagger-children">
      {services.map((service) => (
        <div class="services__card glass animate-on-scroll hover-lift">
          <div class="services__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"
              set:html={icons[service.icon]}
            />
          </div>
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-desc">{service.description}</p>
          <div class="services__card-shine" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .services__card {
    position: relative;
    padding: var(--space-2xl);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .services__card:hover {
    box-shadow: var(--shadow-glow);
  }

  .services__card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      hsla(192, 75%, 48%, 0.04),
      transparent
    );
    transition: left 0.6s ease;
    pointer-events: none;
  }

  .services__card:hover .services__card-shine {
    left: 100%;
  }

  .services__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-brand);
    border-radius: var(--radius-lg);
    color: white;
    margin-bottom: var(--space-lg);
    box-shadow: 0 4px 16px hsla(192, 75%, 48%, 0.2);
  }

  .services__card-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-md);
  }

  .services__card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-normal);
  }

  @media (max-width: 768px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
