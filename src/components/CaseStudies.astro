---
const cases = [
  {
    company: 'PRODALSA',
    status: 'En curso',
    statusColor: 'active',
    description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.',
    challenge: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent commodo cursus magna, vel scelerisque nisl consectetur.',
    solution: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nullam quis risus eget urna mollis ornare vel eu leo.',
    technologies: ['Análisis de Procesos', 'Gestión de Proyectos', 'Auditoría IT', 'Transformación Digital'],
    results: [
      { metric: 'Procesos relevados', value: 'Lorem' },
      { metric: 'Mejoras propuestas', value: 'Lorem' },
      { metric: 'Áreas impactadas', value: 'Lorem' },
    ],
  },
];
---

<section class="cases section section--alt" id="casos">
  <div class="container">
    <div class="cases__header animate-on-scroll">
      <span class="section-label">Casos de éxito</span>
      <h2 class="section-title">
        Proyectos que <span class="text-gradient">generan impacto</span>
      </h2>
      <p class="section-subtitle">
        Conocé los proyectos en los que estamos trabajando y los resultados que logramos junto a nuestros clientes.
      </p>
    </div>

    <div class="cases__list stagger-children">
      {cases.map((caseItem) => (
        <article class="cases__card glass animate-on-scroll">
          <!-- Header -->
          <div class="cases__card-header">
            <div class="cases__card-company">
              <div class="cases__card-logo">
                <span>{caseItem.company.charAt(0)}</span>
              </div>
              <div>
                <h3 class="cases__card-name">{caseItem.company}</h3>
                <span class={`cases__card-status cases__card-status--${caseItem.statusColor}`}>
                  <span class="cases__card-status-dot"></span>
                  {caseItem.status}
                </span>
              </div>
            </div>
          </div>

          <!-- Body -->
          <div class="cases__card-body">
            <p class="cases__card-desc">{caseItem.description}</p>

            <div class="cases__card-sections">
              <div class="cases__card-section">
                <h4 class="cases__card-section-title">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                    <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                  Desafío
                </h4>
                <p>{caseItem.challenge}</p>
              </div>
              <div class="cases__card-section">
                <h4 class="cases__card-section-title">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2"/>
                  </svg>
                  Solución
                </h4>
                <p>{caseItem.solution}</p>
              </div>
            </div>
          </div>

          <!-- Technologies -->
          <div class="cases__card-tech">
            {caseItem.technologies.map((tech) => (
              <span class="cases__card-tag">{tech}</span>
            ))}
          </div>

          <!-- Results -->
          <div class="cases__card-results">
            {caseItem.results.map((result) => (
              <div class="cases__card-result">
                <span class="cases__card-result-value">{result.value}</span>
                <span class="cases__card-result-metric">{result.metric}</span>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cases__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cases__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 900px;
    margin: 0 auto;
  }

  .cases__card {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .cases__card:hover {
    box-shadow: var(--shadow-glow);
    border-color: var(--color-border-hover);
  }

  /* Header */
  .cases__card-header {
    padding: var(--space-xl) var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .cases__card-company {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .cases__card-logo {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-brand);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-extrabold);
    color: white;
  }

  .cases__card-name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
  }

  .cases__card-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cases__card-status--active {
    color: var(--color-success);
  }

  .cases__card-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 6px currentColor;
  }

  /* Body */
  .cases__card-body {
    padding: var(--space-xl) var(--space-2xl);
  }

  .cases__card-desc {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    line-height: var(--line-height-normal);
  }

  .cases__card-sections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .cases__card-section-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .cases__card-section p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-normal);
  }

  /* Technologies */
  .cases__card-tech {
    padding: 0 var(--space-2xl) var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .cases__card-tag {
    padding: 0.3rem 0.75rem;
    background: hsla(192, 75%, 48%, 0.08);
    border: 1px solid hsla(192, 75%, 48%, 0.15);
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-light);
  }

  /* Results */
  .cases__card-results {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-border);
  }

  .cases__card-result {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg);
    text-align: center;
  }

  .cases__card-result:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .cases__card-result-value {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-extrabold);
    background: var(--gradient-brand-text);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-xs);
  }

  .cases__card-result-metric {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .cases__card-header,
    .cases__card-body,
    .cases__card-tech {
      padding-left: var(--space-lg);
      padding-right: var(--space-lg);
    }

    .cases__card-sections {
      grid-template-columns: 1fr;
    }

    .cases__card-results {
      grid-template-columns: 1fr;
    }

    .cases__card-result:not(:last-child) {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
