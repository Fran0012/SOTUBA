---
const team = [
  { name: 'Sofía Olivera', role: 'Consultora', initials: 'SO' },
  { name: 'Franco Di Iasi', role: 'Consultor', initials: 'FD' },
  { name: 'Francisco Regoli Freire', role: 'Consultor', initials: 'FR' },
  { name: 'Daniel Claudio', role: 'Consultor', initials: 'DC' },
  { name: 'Agustín García de la Mata', role: 'Consultor', initials: 'AG' },
  { name: 'Alan Prado', role: 'Consultor', initials: 'AP' },
];
---

<section class="team section section--alt" id="equipo">
  <div class="container">
    <div class="team__header animate-on-scroll">
      <span class="section-label">Equipo</span>
      <h2 class="section-title">
        Las personas detrás de <span class="text-gradient">SOTUBA</span>
      </h2>
      <p class="section-subtitle">
        Un equipo multidisciplinario de estudiantes de la UBA comprometidos con la excelencia.
      </p>
    </div>

    <div class="team__grid stagger-children">
      {team.map((member) => (
        <div class="team__card animate-on-scroll">
          <div class="team__card-avatar">
            <!-- Placeholder avatar — replace with <img> when photos are ready -->
            <!-- To use real photos, place images in public/team/ and uncomment: -->
            <!-- <img src={`${import.meta.env.BASE_URL}team/${member.name.toLowerCase().replace(/ /g, '-')}.webp`} alt={member.name} /> -->
            <span class="team__card-initials">{member.initials}</span>
          </div>
          <div class="team__card-info">
            <h3 class="team__card-name">{member.name}</h3>
            <span class="team__card-role">{member.role}</span>
          </div>
          <div class="team__card-glow" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .team__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .team__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-2xl) var(--space-lg);
    background: var(--color-bg-glass);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-align: center;
    transition: all var(--transition-base);
    overflow: hidden;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .team__card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .team__card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, hsla(192, 75%, 48%, 0.04), transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .team__card:hover .team__card-glow {
    opacity: 1;
  }

  /* Avatar */
  .team__card-avatar {
    width: 88px;
    height: 88px;
    border-radius: var(--radius-full);
    background: var(--gradient-brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg);
    position: relative;
    box-shadow: 0 4px 20px var(--color-accent-glow);
    overflow: hidden;
  }

  .team__card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-full);
  }

  .team__card-initials {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-extrabold);
    color: white;
    letter-spacing: 0.04em;
  }

  /* Info */
  .team__card-name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-xs);
  }

  .team__card-role {
    font-size: var(--font-size-sm);
    color: var(--color-accent-light);
    font-weight: var(--font-weight-medium);
  }

  @media (max-width: 768px) {
    .team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .team__grid {
      grid-template-columns: 1fr;
      max-width: 320px;
    }
  }
</style>
